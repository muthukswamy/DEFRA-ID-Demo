# Server
PORT=3000
NODE_ENV=development

# Session (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Enable authentication (set to false to bypass auth in development)
ENABLE_DEFRA_ID=true

# OIDC Well-Known URL - DEFRA Customer Identity custom domain
DEFRA_ID_WELL_KNOWN_URL=https://your-account.cpdev.cui.defra.gov.uk/idphub/b2c/b2c_1a_cui_cpdev_signupsignin/.well-known/openid-configuration

# OAuth Client Credentials
DEFRA_ID_CLIENT_ID=your-client-id-here
DEFRA_ID_CLIENT_SECRET=your-client-secret-here

# Service ID (provided during DEFRA ID onboarding)
DEFRA_ID_SERVICE_ID=your-service-id-here

# Scope format: openid,offline_access,<DEFRA_ID_CLIENT_ID>
# Including the client ID returns an access token for downstream APIs
DEFRA_ID_SCOPES=openid,offline_access,your-client-id-here

# OAuth Callback URL (must be registered with DEFRA Customer Identity)
DEFRA_ID_REDIRECT_URL=http://localhost:3000/login/return

# Post-logout redirect URL (must be registered with DEFRA Customer Identity)
DEFRA_ID_POST_LOGOUT_URL=http://localhost:3000/signed-out

# Enable automatic token refresh using refresh_token
DEFRA_ID_REFRESH_TOKENS=true

# Optional: Authentication assurance level (1=password only, 2=MFA required)
# DEFRA_ID_AAL=1

# Optional: Force MFA even if already authenticated (true/false)
# DEFRA_ID_FORCE_MFA=false

# Optional: Prompt org reselection for multi-org users (true/false)
# DEFRA_ID_FORCE_RESELECTION=false

# Optional: Pre-select a known relationship ID
# DEFRA_ID_RELATIONSHIP_ID=

# Account management app URL
DEFRA_ACCOUNT_URL=https://your-account.cpdev.cui.defra.gov.uk/management/account-management/me

# Optional: Override the organisation enrolment URL
# Auto-derived from DEFRA_ACCOUNT_URL if not set (resolves to /management/journey/add-sibling-account/start)
# DEFRA_ENROL_ORG_URL=
