{% extends "layouts/base.njk" %}

{% block pageTitle %}Start – {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">{{ serviceName }}</h1>

      <p class="govuk-body-l">
        This service demonstrates DEFRA ID integration using the OpenID Connect
        authorisation code flow with PKCE.
      </p>

      <p class="govuk-body">Use this service to:</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>sign in using DEFRA ID (Azure AD B2C)</li>
        <li>view your account details and linked accounts</li>
        <li>inspect the JWT token claims returned by DEFRA ID</li>
        <li>test sign-out and token refresh behaviour</li>
      </ul>

      {% if isAuthenticated %}
        {{ govukButton({
          text: "Go to your dashboard",
          href: "/dashboard",
          isStartButton: true,
          classes: "govuk-!-margin-top-4"
        }) }}
      {% else %}
        {{ govukButton({
          text: "Sign in with DEFRA ID",
          href: "/login",
          isStartButton: true,
          classes: "govuk-!-margin-top-4"
        }) }}
      {% endif %}

      <h2 class="govuk-heading-m">Before you start</h2>
      <p class="govuk-body">
        You will need a DEFRA ID account. If you do not have one, you can
        create one when you sign in.
      </p>

      <h2 class="govuk-heading-m">About this service</h2>
      <p class="govuk-body">
        This is a mock service for demonstration and onboarding purposes only.
        It uses the CPDEV environment of the DEFRA Customer Identity service.
      </p>

    </div>

    <div class="govuk-grid-column-one-third">
      <aside class="govuk-!-padding-4" style="background:#f3f2f1; border-left:4px solid #1d70b8;">
        <h2 class="govuk-heading-s">Technical details</h2>
        <ul class="govuk-list govuk-list--bullet govuk-!-font-size-16">
          <li>OIDC authorization code flow</li>
          <li>PKCE (S256)</li>
          <li>Response mode: form_post</li>
          <li>Token validation via JWKS</li>
          <li>Silent token refresh</li>
        </ul>
      </aside>
    </div>
  </div>
{% endblock %}
