{% extends "layouts/base.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block pageTitle %}New record – {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Dashboard", href: "/dashboard" },
      { text: "Records", href: "/records" },
      { text: "New record" }
    ]
  }) }}
{% endblock %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">{{ currentOrg.organisationName }}</span>
      <h1 class="govuk-heading-xl">New record</h1>

      {% if errors %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            { text: errors.title.text, href: "#title" }
          ]
        }) }}
      {% endif %}

      <form method="POST" action="/records" novalidate>
        {{ govukInput({
          label: { text: "Title", classes: "govuk-label--m" },
          id: "title",
          name: "title",
          value: (values.title if values else ""),
          errorMessage: (errors.title if errors else null)
        }) }}

        {{ govukTextarea({
          label: { text: "Description", classes: "govuk-label--m" },
          hint: { text: "A short summary of what this record is about." },
          id: "description",
          name: "description",
          value: (values.description if values else ""),
          rows: 3
        }) }}

        {{ govukTextarea({
          label: { text: "Body", classes: "govuk-label--m" },
          hint: { text: "The main content of this record." },
          id: "body",
          name: "body",
          value: (values.body if values else ""),
          rows: 8
        }) }}

        {{ govukButton({ text: "Create record" }) }}
        <a href="/records" class="govuk-link govuk-!-margin-left-3">Cancel</a>
      </form>

    </div>
  </div>

{% endblock %}
