{% extends "layouts/base.njk" %}

{% block pageTitle %}Share {{ record.title }} – {{ serviceName }}{% endblock %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Dashboard", href: "/dashboard" },
      { text: "Records", href: "/records" },
      { text: record.title, href: "/records/" + record.id },
      { text: "Share" }
    ]
  }) }}
{% endblock %}

{% block content %}

  {% if errorMessage %}
    {{ govukErrorSummary({ titleText: "There is a problem", errorList: [{ text: errorMessage }] }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">{{ currentOrg.organisationName }}</span>
      <h1 class="govuk-heading-xl">Share record</h1>
      <p class="govuk-body">Manage who can access <strong>{{ record.title }}</strong>.</p>

      {# ------------------------------------------------------------------ #}
      {# Section 1: Whole-organisation access                                #}
      {# ------------------------------------------------------------------ #}
      <h2 class="govuk-heading-m">Whole-organisation access</h2>

      {% if orgGrant %}
        {{ govukInsetText({
          html: "All organisation members can <strong>" + orgGrant.permission + "</strong> this record."
        }) }}
        <form method="POST" action="/records/{{ record.id }}/share">
          <input type="hidden" name="_action" value="org-revoke">
          {{ govukButton({ text: "Remove organisation access", classes: "govuk-button--warning govuk-button--secondary" }) }}
        </form>
      {% else %}
        <p class="govuk-body">No organisation-wide access is set — only people listed below can access this record.</p>
        <form method="POST" action="/records/{{ record.id }}/share" class="govuk-!-margin-bottom-6">
          <input type="hidden" name="_action" value="org-grant">
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="orgPermission">Grant organisation access at level</label>
            <select class="govuk-select" id="orgPermission" name="orgPermission">
              <option value="viewer">Viewer — read only</option>
              <option value="editor">Editor — view and edit</option>
            </select>
          </div>
          {{ govukButton({ text: "Grant organisation access", classes: "govuk-button--secondary" }) }}
        </form>
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

      {# ------------------------------------------------------------------ #}
      {# Section 2: Admin access (automatic, read-only)                     #}
      {# ------------------------------------------------------------------ #}
      <h2 class="govuk-heading-m">Admin access</h2>
      {% if adminGrant %}
        <p class="govuk-body">All org admins have <strong>{{ adminGrant.permission }}</strong> access (automatic — cannot be changed).</p>
      {% else %}
        <p class="govuk-body govuk-hint">No automatic admin access on this record.</p>
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

      {# ------------------------------------------------------------------ #}
      {# Section 3: Individual grants                                        #}
      {# ------------------------------------------------------------------ #}
      <h2 class="govuk-heading-m">Individual access</h2>

      {% if individualGrants.length > 0 %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th class="govuk-table__header">Person</th>
              <th class="govuk-table__header">Email</th>
              <th class="govuk-table__header">Access</th>
              <th class="govuk-table__header">Action</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for g in individualGrants %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ g.displayName or "—" }}</td>
                <td class="govuk-table__cell">{{ g.email or "—" }}</td>
                <td class="govuk-table__cell">
                  {% if g.permission == "owner" %}
                    <strong class="govuk-tag govuk-tag--purple">Owner</strong>
                  {% elif g.permission == "editor" %}
                    <strong class="govuk-tag govuk-tag--blue">Editor</strong>
                  {% else %}
                    <strong class="govuk-tag govuk-tag--grey">Viewer</strong>
                  {% endif %}
                  {% if g.redundant %}
                    <span class="govuk-hint govuk-!-font-size-16 govuk-!-margin-top-1 govuk-!-display-block">Covered by organisation access</span>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  {% if g.permission != "owner" %}
                    <form method="POST" action="/records/{{ record.id }}/share" style="margin:0">
                      <input type="hidden" name="_action" value="revoke">
                      <input type="hidden" name="grantee" value="{{ g.grantee }}">
                      <button type="submit" class="govuk-link" style="border:0;background:none;cursor:pointer;padding:0;font-size:inherit">Remove</button>
                    </form>
                  {% else %}
                    <span class="govuk-hint" style="margin:0">—</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body govuk-hint">No individual grants yet.</p>
      {% endif %}

      {# ------------------------------------------------------------------ #}
      {# Section 4: Grant individual access                                   #}
      {# ------------------------------------------------------------------ #}
      {% if shareableMembers.length > 0 %}
        <h2 class="govuk-heading-m">Grant individual access</h2>
        <form method="POST" action="/records/{{ record.id }}/share">
          <input type="hidden" name="_action" value="grant">
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="grantee">Person</label>
            <select class="govuk-select" id="grantee" name="grantee">
              {% for m in shareableMembers %}
                <option value="{{ m.sub }}">{{ m.displayName or m.email or m.sub }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="permission">Access level</label>
            <select class="govuk-select" id="permission" name="permission">
              <option value="viewer">Viewer — read only</option>
              <option value="editor">Editor — view and edit</option>
            </select>
          </div>
          {{ govukButton({ text: "Grant access", classes: "govuk-button--secondary" }) }}
        </form>
      {% elif individualGrants.length <= 1 and not orgGrant %}
        {{ govukInsetText({
          text: "There are no other organisation members to share this record with."
        }) }}
      {% endif %}

      {% if permissionHistory and permissionHistory.length > 0 %}
        <details class="govuk-details govuk-!-margin-top-6">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Record permission history</span>
          </summary>
          <div class="govuk-details__text">
            <table class="govuk-table govuk-!-margin-bottom-0">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th class="govuk-table__header">Date</th>
                  <th class="govuk-table__header">Event</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                {% for h in permissionHistory %}
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell govuk-body-s" style="white-space:nowrap">{{ h.occurredAtFormatted }}</td>
                    <td class="govuk-table__cell govuk-body-s">
                      {% if h.event == "permission_granted" %}
                        <strong>{{ h.actorName }}</strong> granted <strong>{{ h.targetName }}</strong> {{ h.detail }} access
                      {% elif h.event == "permission_revoked" %}
                        <strong>{{ h.actorName }}</strong> removed {{ h.targetName }}'s access
                      {% elif h.event == "owner_claimed" %}
                        Ownership transferred from <strong>{{ h.targetName }}</strong> to <strong>{{ h.actorName }}</strong>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </details>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-4">
        <a href="/records/{{ record.id }}" class="govuk-link">Back to record</a>
      </p>

    </div>
  </div>

{% endblock %}
