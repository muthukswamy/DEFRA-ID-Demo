{% extends "layouts/base.njk" %}

{% block pageTitle %}Signed out – {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-panel govuk-panel--confirmation">
        <h1 class="govuk-panel__title">You have signed out</h1>
        <div class="govuk-panel__body">
          {{ serviceName }}
        </div>
      </div>

      <p class="govuk-body govuk-!-margin-top-6">
        You have been signed out of {{ serviceName }}.
        Your DEFRA ID session may still be active in your browser.
      </p>
      <p class="govuk-body">
        To protect your account, close your browser window if you are on a
        shared device.
      </p>

      {{ govukButton({
        text: "Sign in",
        href: "/login"
      }) }}

      {% if idToken and endSessionUrl %}
        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <h2 class="govuk-heading-m govuk-!-margin-top-4">Also sign out of DEFRA ID?</h2>
        <p class="govuk-body">
          Your DEFRA ID account session may still be active in this browser. If you
          are on a shared or public device, sign out of DEFRA ID completely.
        </p>

        <form method="POST" action="{{ endSessionUrl }}" target="_blank" rel="noopener noreferrer">
          <input type="hidden" name="id_token_hint" value="{{ idToken }}">
          <input type="hidden" name="post_logout_redirect_uri" value="{{ postLogoutRedirectUri }}">
          {{ govukButton({
            text: "Sign out of DEFRA ID",
            classes: "govuk-button--secondary"
          }) }}
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
