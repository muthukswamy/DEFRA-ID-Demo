{% extends "layouts/base.njk" %}

{% block pageTitle %}Signing out – {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">Signing you out…</h1>
      <p class="govuk-body">Please wait while we sign you out.</p>
    </div>
  </div>

  {#
    Hidden form auto-submitted by JS.
    CORS prevents a JS fetch/XHR to the end_session_endpoint, so a standard
    HTML form POST is required as per DEFRA ID documentation.
    The id_token_hint is required for the post_logout_redirect_uri to work.
  #}
  <form
    id="signout-form"
    method="POST"
    action="{{ endSessionEndpoint }}"
  >
    <input type="hidden" name="id_token_hint" value="{{ idTokenHint }}">
    <input type="hidden" name="post_logout_redirect_uri" value="{{ postLogoutRedirectUri }}">
    <input type="hidden" name="state" value="{{ state }}">

    <noscript>
      <p class="govuk-body">
        Scripts are disabled. Click the button below to complete sign out.
      </p>
      <button type="submit" class="govuk-button">Sign out</button>
    </noscript>
  </form>
{% endblock %}

{% block bodyEnd %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.getElementById('signout-form').submit()
    })
  </script>
{% endblock %}
