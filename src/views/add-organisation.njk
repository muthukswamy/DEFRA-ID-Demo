{% extends "layouts/base.njk" %}

{% block pageTitle %}Enrol an account – {{ serviceName }}{% endblock %}


{% block beforeContent %}
  <a href="/account" class="govuk-back-link">Back</a>
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Enrol an account with this service</h1>

      <p class="govuk-body">
        Before an account can be used with this service it must be enrolled. Use this
        page whether you are enrolling an account that already exists in DEFRA ID, or
        you need to create one first.
      </p>

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      {# ── Section 1: Create a new account ─────────────────────────────── #}
      <h2 class="govuk-heading-l">If you need to create a new account first</h2>

      <p class="govuk-body">
        If you do not yet have an account in DEFRA ID for your organisation, you must
        create one before you can enrol it with this service.
      </p>

      <ol class="govuk-list govuk-list--number govuk-!-margin-bottom-2">
        <li>
          <strong>Go to DEFRA account management.</strong>
          <br>
          <a href="{{ defraAccountUrl }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
            Open DEFRA account management <span class="govuk-visually-hidden">(opens in new tab)</span>
          </a>
        </li>
        <li class="govuk-!-margin-top-4">
          <strong>Create your organisation account.</strong>
          <br>
          Follow the steps in DEFRA account management to set up a new account for
          your organisation.
        </li>
        <li class="govuk-!-margin-top-4">
          <strong>Once created, follow the steps below to enrol it with this service.</strong>
        </li>
      </ol>

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      {# ── Section 2: Enrol existing account ───────────────────────────── #}
      <h2 class="govuk-heading-l">Enrol your account with this service</h2>

      <p class="govuk-body">
        Follow these steps in DEFRA account management to enrol an existing account
        with {{ serviceName }}.
      </p>

      <ol class="govuk-list govuk-list--number govuk-!-margin-bottom-6">
        <li>
          <strong>Go to your accounts in DEFRA account management.</strong>
          <br>
          <a href="{{ defraAccountUrl }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
            Open DEFRA account management <span class="govuk-visually-hidden">(opens in new tab)</span>
          </a>
          <br>
          You will see a table headed <strong>"Your accounts"</strong> listing your
          accounts and their enrolled services.
        </li>
        <li class="govuk-!-margin-top-4">
          <strong>Find the account and open it.</strong>
          <br>
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-top-2">
            <li>
              <strong>For an organisation account</strong> — click <strong>"Manage"</strong>.
              On the account page, click the <strong>"Register for more services"</strong> button.
            </li>
            <li>
              <strong>For a personal account</strong> — click <strong>"Add a service"</strong>
              directly.
            </li>
          </ul>
        </li>
        <li class="govuk-!-margin-top-4">
          <strong>Find <em>{{ serviceName }}</em> in the list and click its link.</strong>
          <br>
          You will see a <strong>"Register for more services"</strong> page with a
          list of available services. Click <strong>{{ serviceName }}</strong> to
          begin enrolment.
        </li>
        <li class="govuk-!-margin-top-4">
          <strong>Complete the enrolment, then click the button below.</strong>
          <br>
          Once enrolled, the account will appear in the account picker when you sign in.
        </li>
      </ol>

      {{ govukButton({
        text: "I've enrolled my account — sign in",
        href: "/login/switch-org"
      }) }}

      <p class="govuk-body">
        <a href="/account" class="govuk-link">Cancel and return to manage account</a>
      </p>
    </div>
  </div>
{% endblock %}
