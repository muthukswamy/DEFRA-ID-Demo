{% extends "layouts/base.njk" %}

{% block pageTitle %}There is a problem signing you in – {{ serviceName }}{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">There is a problem signing you in</h1>

      {% if errorCode == "access_denied" %}
        <p class="govuk-body">You cancelled the sign-in process. Try again when you are ready.</p>
      {% elif errorCode == "login_required" %}
        <p class="govuk-body">Your session has expired. Please sign in again to continue.</p>
      {% elif errorCode == "interaction_required" %}
        <p class="govuk-body">Further action is needed to complete sign-in. Please try again.</p>
      {% else %}
        <p class="govuk-body">We were unable to sign you in. This may be because:</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>your session has expired</li>
          <li>you cancelled the sign-in process</li>
          <li>you do not have access to this service</li>
          <li>there was a temporary problem with DEFRA ID</li>
        </ul>
      {% endif %}

      {% if errorCode %}
        {{ govukInsetText({
          html: "<strong>" + errorCode + "</strong>" + (" — " + errorDescription if errorDescription else "")
        }) }}
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        {{ govukButton({
          text: "Try signing in again",
          href: "/login"
        }) }}
      </p>
      <p class="govuk-body">
        or <a href="/" class="govuk-link">go to the start page</a>
      </p>
    </div>
  </div>
{% endblock %}
