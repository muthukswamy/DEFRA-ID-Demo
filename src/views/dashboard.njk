{% extends "layouts/base.njk" %}

{% block pageTitle %}Dashboard – {{ serviceName }}{% endblock %}

{% block content %}
  {% if user.enrolmentRequestCount > 0 %}
    {{ govukNotificationBanner({
      html: "You have <strong>" + user.enrolmentRequestCount + "</strong> pending enrolment request(s). <a href='/account' class='govuk-notification-banner__link'>View in Manage account</a>"
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">
        Welcome, {{ user.displayName or "there" }}
      </h1>

      <p class="govuk-body-l">
        {% if currentOrg and currentOrg.organisationName %}
          Signed in as <strong>{{ currentOrg.organisationName }}</strong>
        {% else %}
          Signed in as an individual account
        {% endif %}
      </p>

      {% if serviceRole %}
        <p class="govuk-body govuk-!-margin-bottom-1">
          Your service role:
          {% if serviceRole == "admin" %}
            {{ govukTag({ text: "Admin", classes: "govuk-tag--green" }) }}
          {% else %}
            {{ govukTag({ text: "Member", classes: "govuk-tag--grey" }) }}
          {% endif %}
        </p>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="/account" class="govuk-link">Manage your account</a>
        {% if isOrgAdmin and currentOrg %}
          &nbsp;·&nbsp;
          <a href="/team" class="govuk-link">Manage team access</a>
        {% endif %}
      </p>

    </div>
  </div>
{% endblock %}
