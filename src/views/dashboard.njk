{% extends "layouts/base.njk" %}

{% block pageTitle %}Dashboard – {{ serviceName }}{% endblock %}


{% block content %}
  {% if refreshed == "1" %}
    {{ govukNotificationBanner({
      type: "success",
      titleText: "Token refreshed",
      text: "Your access token has been refreshed successfully."
    }) }}
  {% elif refreshed == "error" %}
    {{ govukNotificationBanner({
      type: "important",
      titleText: "Refresh failed",
      text: "Could not refresh your token. Try signing out and back in."
    }) }}
  {% elif refreshed == "no-token" %}
    {{ govukNotificationBanner({
      type: "important",
      titleText: "No refresh token",
      text: "No refresh token is available in this session."
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl">Your account</h1>
    </div>
  </div>

  {# ── Personal details ─────────────────────────────────────────────────── #}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Personal details</h2>
      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Name" },
            value: { text: user.displayName or "—" }
          },
          {
            key: { text: "Email" },
            value: { text: user.email or "—" }
          },
          {
            key: { text: "Unique reference" },
            value: { html: "<code>" + (user.uniqueReference or "—") + "</code>" }
          },
          {
            key: { text: "Contact ID" },
            value: { html: "<code class='govuk-!-font-size-16'>" + (user.contactId or "—") + "</code>" }
          },
          {
            key: { text: "Subject (sub)" },
            value: { html: "<code class='govuk-!-font-size-16'>" + (user.sub or "—") + "</code>" }
          }
        ]
      }) }}

      {# ── Authentication details ──────────────────────────────────────── #}
      <h2 class="govuk-heading-l govuk-!-margin-top-6">Authentication</h2>
      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Authentication assurance level (AAL)" },
            value: {
              html: govukTag({ text: "AAL " + (user.aal or "—"), classes: "govuk-tag--blue" })
            }
          },
          {
            key: { text: "Level of assurance (LOA)" },
            value: { text: user.loa if user.loa is not none else "—" }
          },
          {
            key: { text: "Authentication method (AMR)" },
            value: { text: user.amr | join(", ") if user.amr.length else "—" }
          },
          {
            key: { text: "Session ID" },
            value: { html: "<code class='govuk-!-font-size-16'>" + (user.sessionId or "—") + "</code>" }
          },
          {
            key: { text: "Correlation ID" },
            value: { html: "<code class='govuk-!-font-size-16'>" + (user.correlationId or "—") + "</code>" }
          },
          {
            key: { text: "Service ID" },
            value: { html: "<code class='govuk-!-font-size-16'>" + (user.serviceId or "—") + "</code>" }
          },
          {
            key: { text: "Access token expires" },
            value: {
              html: "<span class='app-token-expiry' data-expires='" + (tokenExpiresAt or "") + "'>—</span>"
            }
          }
        ]
      }) }}

      <div class="govuk-!-margin-top-4">
        {% if hasRefreshToken %}
          <form method="POST" action="/refresh">
            {{ govukButton({
              text: "Refresh token now",
              classes: "govuk-button--secondary govuk-!-margin-bottom-0"
            }) }}
          </form>
        {% else %}
          <p class="govuk-body govuk-!-font-size-16 govuk-!-color-secondary">
            No refresh token — token cannot be refreshed manually.
          </p>
        {% endif %}
      </div>
    </div>

    <div class="govuk-grid-column-one-third">
      {# ── Enrolment counts ────────────────────────────────────────────── #}
      <h2 class="govuk-heading-m">Enrolments</h2>
      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Enrolled with this service" },
            value: { text: user.enrolmentCount }
          },
          {
            key: { text: "Pending requests" },
            value: { text: user.enrolmentRequestCount }
          }
        ]
      }) }}

      {% if user.enrolmentRequestCount > 0 %}
        {{ govukInsetText({
          text: "You have " + user.enrolmentRequestCount + " pending enrolment request(s). Once approved, those organisations will appear in the org picker."
        }) }}
      {% endif %}

      <p class="govuk-body govuk-!-font-size-16">
        Only organisations enrolled with this service appear in the sign-in org picker.
      </p>

      <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

      {% if user.enrolmentCount > 1 %}
        {{ govukButton({
          text: "Switch enrolled organisation",
          href: "/login/switch-org",
          classes: "govuk-button--secondary govuk-!-margin-bottom-2"
        }) }}
      {% else %}
        <p class="govuk-body govuk-!-font-size-16 govuk-!-margin-bottom-2">
          You only have one organisation enrolled with this service.<br>
          Use <strong>Enrol an organisation</strong> below to enrol another.
        </p>
      {% endif %}

      {{ govukButton({
        text: "Enrol an organisation",
        href: "/add-organisation",
        classes: "govuk-button--secondary govuk-!-margin-bottom-2"
      }) }}

      <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

      <p class="govuk-body govuk-!-font-size-16">
        <a href="{{ defraAccountUrl }}" class="govuk-link" target="_blank" rel="noopener noreferrer">
          Manage your DEFRA account <span class="govuk-visually-hidden">(opens in new tab)</span>
        </a>
      </p>
    </div>
  </div>

  {# ── Current organisation ─────────────────────────────────────────────── #}
  {% if currentOrg %}
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-full">
        <h2 class="govuk-heading-l">Current organisation</h2>
      </div>
      <div class="govuk-grid-column-two-thirds">
        {{ govukSummaryList({
          rows: [
            {
              key: { text: "Organisation name" },
              value: { text: currentOrg.organisationName }
            },
            {
              key: { text: "Organisation ID" },
              value: { html: "<code class='govuk-!-font-size-16'>" + currentOrg.organisationId + "</code>" }
            },
            {
              key: { text: "Relationship type" },
              value: { text: currentOrg.relationship }
            },
            {
              key: { text: "Organisation LOA" },
              value: { text: currentOrg.organisationLoa }
            },
            {
              key: { text: "Relationship LOA" },
              value: { text: currentOrg.relationshipLoa }
            }
          ]
        }) }}
      </div>
    </div>
  {% endif %}

  {# ── All linked organisations ─────────────────────────────────────────── #}
  {% if user.relationships and user.relationships.length > 0 %}
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-full">
        <h2 class="govuk-heading-l">
          Linked organisations
          <span class="govuk-!-font-size-19 govuk-!-font-weight-regular govuk-!-color-secondary">
            ({{ user.relationships.length }})
          </span>
        </h2>
        {% if user.relationshipsFromStore %}
          <p class="govuk-body govuk-!-font-size-16">
            Some organisations below were seen in a previous sign-in and may not be in your
            current token. Switch org or refresh the token to update.
          </p>
        {% endif %}
        {{ govukTable({
          head: [
            { text: "Organisation name" },
            { text: "Organisation ID" },
            { text: "Relationship" },
            { text: "LOA" }
          ],
          rows: relationshipRows
        }) }}
      </div>
    </div>
  {% endif %}

  {# ── Roles ────────────────────────────────────────────────────────────── #}
  {% if user.roles and user.roles.length > 0 %}
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-full">
        <h2 class="govuk-heading-l">
          Roles
          <span class="govuk-!-font-size-19 govuk-!-font-weight-regular">
            ({{ user.roles.length }})
          </span>
        </h2>
        {{ govukTable({
          head: [
            { text: "Role name" },
            { text: "Status" },
            { text: "Relationship ID" }
          ],
          rows: roleRows
        }) }}
      </div>
    </div>
  {% endif %}

  {# ── No org/roles message ─────────────────────────────────────────────── #}
  {% if (not user.relationships or user.relationships.length === 0) and (not user.roles or user.roles.length === 0) %}
    <div class="govuk-grid-row govuk-!-margin-top-2">
      <div class="govuk-grid-column-two-thirds">
        {{ govukNotificationBanner({
          text: "No organisations or roles are linked to your account for this service."
        }) }}
      </div>
    </div>
  {% endif %}

  {# ── Raw token claims ─────────────────────────────────────────────────── #}
  <div class="govuk-grid-row govuk-!-margin-top-4">
    <div class="govuk-grid-column-full">
      <details class="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">Raw token claims (JSON)</span>
        </summary>
        <div class="govuk-details__text">
          <pre class="app-raw-claims">{{ rawClaims }}</pre>
        </div>
      </details>
    </div>
  </div>

{% endblock %}

{% block bodyEnd %}
  <script>
    // ── Token expiry display ──────────────────────────────────────────────
    const expiryEl = document.querySelector('.app-token-expiry')
    if (expiryEl) {
      const exp = parseInt(expiryEl.dataset.expires, 10)
      if (exp) {
        const update = () => {
          const now = Math.floor(Date.now() / 1000)
          const diff = exp - now
          const date = new Date(exp * 1000)
          const time = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' })
          if (diff > 0) {
            const m = Math.floor(diff / 60)
            const s = diff % 60
            expiryEl.textContent = time + ' (in ' + (m > 0 ? m + ' min ' : '') + s + ' sec)'
          } else {
            expiryEl.textContent = time + ' (expired)'
          }
        }
        update()
        setInterval(update, 1000)
      }
    }

    // ── Copy-to-clipboard ─────────────────────────────────────────────────
    // Attach a Copy button after every <code> element that has a non-trivial value.
    document.querySelectorAll('code').forEach(function (el) {
      const text = el.textContent.trim()
      if (!text || text === '—') return
      const btn = document.createElement('button')
      btn.className = 'app-copy-btn'
      btn.type = 'button'
      btn.textContent = 'Copy'
      btn.setAttribute('aria-label', 'Copy value')
      btn.dataset.copy = text
      el.insertAdjacentElement('afterend', btn)
    })

    document.addEventListener('click', function (e) {
      if (!e.target.matches('.app-copy-btn')) return
      navigator.clipboard.writeText(e.target.dataset.copy).then(function () {
        e.target.textContent = 'Copied!'
        setTimeout(function () { e.target.textContent = 'Copy' }, 2000)
      })
    })
  </script>
{% endblock %}
